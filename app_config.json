{
  "intent": {
    "app_name": "Hospital Management System",
    "app_type": "Healthcare Management",
    "entities": [
      {
        "name": "Doctor",
        "description": "Medical professional",
        "attributes": [
          "name",
          "specialty",
          "schedule"
        ]
      },
      {
        "name": "Patient",
        "description": "Individual receiving medical care",
        "attributes": [
          "name",
          "medical history",
          "contact info"
        ]
      },
      {
        "name": "Appointment",
        "description": "Scheduled meeting between doctor and patient",
        "attributes": [
          "date",
          "time",
          "doctor",
          "patient"
        ]
      },
      {
        "name": "Bill",
        "description": "Payment request for medical services",
        "attributes": [
          "amount",
          "patient",
          "appointment"
        ]
      }
    ],
    "roles": [
      {
        "name": "Admin",
        "permissions": [
          "manage doctors",
          "manage patients",
          "view appointments",
          "view billing"
        ]
      },
      {
        "name": "Doctor",
        "permissions": [
          "view appointments",
          "view patient info",
          "create bills"
        ]
      },
      {
        "name": "Patient",
        "permissions": [
          "view appointments",
          "view bills"
        ]
      }
    ],
    "features": [
      {
        "name": "Appointment Scheduling",
        "description": "Allow patients to schedule appointments with doctors",
        "requires_auth": true,
        "roles_allowed": [
          "Patient",
          "Doctor",
          "Admin"
        ]
      },
      {
        "name": "Billing Management",
        "description": "Manage payment requests for medical services",
        "requires_auth": true,
        "roles_allowed": [
          "Admin",
          "Doctor"
        ]
      },
      {
        "name": "Patient Profile Management",
        "description": "Manage patient information",
        "requires_auth": true,
        "roles_allowed": [
          "Patient",
          "Doctor",
          "Admin"
        ]
      }
    ],
    "integrations": [
      "Payment Gateway"
    ],
    "assumptions": [
      "Doctors and patients will have unique identifiers",
      "Appointments will have a status (e.g. scheduled, completed, cancelled)"
    ]
  },
  "system_design": {
    "entities": [
      {
        "name": "Doctor",
        "description": "Medical professional",
        "attributes": [
          "name",
          "specialty",
          "schedule"
        ]
      },
      {
        "name": "Patient",
        "description": "Individual receiving medical care",
        "attributes": [
          "name",
          "medical history",
          "contact info"
        ]
      },
      {
        "name": "Appointment",
        "description": "Scheduled meeting between doctor and patient",
        "attributes": [
          "date",
          "time",
          "doctor",
          "patient"
        ]
      },
      {
        "name": "Bill",
        "description": "Payment request for medical services",
        "attributes": [
          "amount",
          "patient",
          "appointment"
        ]
      }
    ],
    "relationships": [
      {
        "name": "Doctor-Patient",
        "description": "A doctor can have many patients",
        "from_entity": "Doctor",
        "to_entity": "Patient",
        "type": "one_to_many"
      },
      {
        "name": "Patient-Appointment",
        "description": "A patient can have many appointments",
        "from_entity": "Patient",
        "to_entity": "Appointment",
        "type": "one_to_many"
      },
      {
        "name": "Doctor-Appointment",
        "description": "A doctor can have many appointments",
        "from_entity": "Doctor",
        "to_entity": "Appointment",
        "type": "one_to_many"
      },
      {
        "name": "Appointment-Bill",
        "description": "An appointment can have one bill",
        "from_entity": "Appointment",
        "to_entity": "Bill",
        "type": "one_to_one"
      }
    ],
    "pages": [
      {
        "name": "LoginPage",
        "path": "/login",
        "description": "Login page for users",
        "access_roles": [
          "Admin",
          "Doctor",
          "Patient"
        ]
      },
      {
        "name": "AppointmentPage",
        "path": "/appointments",
        "description": "Page for viewing and scheduling appointments",
        "access_roles": [
          "Admin",
          "Doctor",
          "Patient"
        ]
      },
      {
        "name": "PatientProfilePage",
        "path": "/patient-profile",
        "description": "Page for viewing and editing patient information",
        "access_roles": [
          "Admin",
          "Doctor",
          "Patient"
        ]
      },
      {
        "name": "BillingPage",
        "path": "/billing",
        "description": "Page for viewing and managing bills",
        "access_roles": [
          "Admin",
          "Doctor"
        ]
      }
    ],
    "api_groups": [
      {
        "name": "Authentication",
        "description": "Endpoints for user authentication",
        "endpoints": [
          {
            "method": "POST",
            "path": "/login",
            "description": "Login endpoint"
          },
          {
            "method": "POST",
            "path": "/register",
            "description": "Registration endpoint"
          }
        ]
      },
      {
        "name": "Appointment Management",
        "description": "Endpoints for managing appointments",
        "endpoints": [
          {
            "method": "GET",
            "path": "/appointments",
            "description": "Get all appointments"
          },
          {
            "method": "POST",
            "path": "/appointments",
            "description": "Create a new appointment"
          },
          {
            "method": "PUT",
            "path": "/appointments/{id}",
            "description": "Update an appointment"
          },
          {
            "method": "DELETE",
            "path": "/appointments/{id}",
            "description": "Delete an appointment"
          }
        ]
      },
      {
        "name": "Patient Profile Management",
        "description": "Endpoints for managing patient information",
        "endpoints": [
          {
            "method": "GET",
            "path": "/patient-profile",
            "description": "Get patient information"
          },
          {
            "method": "PUT",
            "path": "/patient-profile",
            "description": "Update patient information"
          }
        ]
      },
      {
        "name": "Billing Management",
        "description": "Endpoints for managing bills",
        "endpoints": [
          {
            "method": "GET",
            "path": "/billing",
            "description": "Get all bills"
          },
          {
            "method": "POST",
            "path": "/billing",
            "description": "Create a new bill"
          },
          {
            "method": "PUT",
            "path": "/billing/{id}",
            "description": "Update a bill"
          },
          {
            "method": "DELETE",
            "path": "/billing/{id}",
            "description": "Delete a bill"
          }
        ]
      }
    ],
    "flows": [
      {
        "name": "Patient Scheduling Flow",
        "steps": [
          "User opens LoginPage",
          "User logs in as Patient",
          "User navigates to AppointmentPage",
          "User selects a doctor and schedule",
          "User creates a new appointment"
        ]
      },
      {
        "name": "Doctor Viewing Flow",
        "steps": [
          "User opens LoginPage",
          "User logs in as Doctor",
          "User navigates to AppointmentPage",
          "User views their scheduled appointments"
        ]
      },
      {
        "name": "Admin Billing Flow",
        "steps": [
          "User opens LoginPage",
          "User logs in as Admin",
          "User navigates to BillingPage",
          "User views all bills",
          "User updates a bill"
        ]
      }
    ]
  },
