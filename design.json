{
  "entities": [
    {
      "name": "products",
      "description": "items for sale",
      "attributes": [
        "price",
        "description",
        "image"
      ]
    },
    {
      "name": "carts",
      "description": "temporary storage for products",
      "attributes": [
        "items",
        "total"
      ]
    },
    {
      "name": "orders",
      "description": "completed purchases",
      "attributes": [
        "date",
        "total",
        "status"
      ]
    },
    {
      "name": "payments",
      "description": "financial transactions",
      "attributes": [
        "amount",
        "method"
      ]
    },
    {
      "name": "admin dashboard",
      "description": "control panel for administrators",
      "attributes": [
        "analytics",
        "settings"
      ]
    }
  ],
  "relationships": [
    {
      "name": "cart contains products",
      "description": "many-to-many relationship between carts and products",
      "from_entity": "carts",
      "to_entity": "products",
      "type": "many_to_many"
    },
    {
      "name": "order contains products",
      "description": "many-to-many relationship between orders and products",
      "from_entity": "orders",
      "to_entity": "products",
      "type": "many_to_many"
    },
    {
      "name": "payment is associated with order",
      "description": "one-to-one relationship between payments and orders",
      "from_entity": "payments",
      "to_entity": "orders",
      "type": "one_to_one"
    },
    {
      "name": "admin dashboard is used by admin",
      "description": "one-to-one relationship between admin dashboard and admin",
      "from_entity": "admin dashboard",
      "to_entity": "admin",
      "type": "one_to_one"
    }
  ],
  "pages": [
    {
      "name": "Product List Page",
      "path": "/products",
      "description": "display available products",
      "access_roles": [
        "user"
      ]
    },
    {
      "name": "Cart Page",
      "path": "/cart",
      "description": "store products for later purchase",
      "access_roles": [
        "user"
      ]
    },
    {
      "name": "Checkout Page",
      "path": "/checkout",
      "description": "complete purchase",
      "access_roles": [
        "user"
      ]
    },
    {
      "name": "Admin Dashboard",
      "path": "/admin/dashboard",
      "description": "configure platform settings",
      "access_roles": [
        "admin"
      ]
    }
  ],
  "api_groups": [
    {
      "name": "Product API",
      "description": "manage products",
      "endpoints": [
        {
          "method": "GET",
          "path": "/products",
          "description": "display available products"
        },
        {
          "method": "POST",
          "path": "/products",
          "description": "create new product"
        }
      ]
    },
    {
      "name": "Cart API",
      "description": "manage carts",
      "endpoints": [
        {
          "method": "GET",
          "path": "/cart",
          "description": "display cart contents"
        },
        {
          "method": "POST",
          "path": "/cart",
          "description": "add product to cart"
        }
      ]
    },
    {
      "name": "Order API",
      "description": "manage orders",
      "endpoints": [
        {
          "method": "GET",
          "path": "/orders",
          "description": "display completed purchases"
        },
        {
          "method": "POST",
          "path": "/orders",
          "description": "create new order"
        }
      ]
    },
    {
      "name": "Payment API",
      "description": "manage payments",
      "endpoints": [
        {
          "method": "GET",
          "path": "/payments",
          "description": "display financial transactions"
        },
        {
          "method": "POST",
          "path": "/payments",
          "description": "create new payment"
        }
      ]
    },
    {
      "name": "Admin API",
      "description": "manage admin settings",
      "endpoints": [
        {
          "method": "GET",
          "path": "/admin/dashboard",
          "description": "display admin dashboard"
        },
        {
          "method": "POST",
          "path": "/admin/dashboard",
          "description": "update admin settings"
        }
      ]
    }
  ],
  "flows": [
    {
      "name": "User Checkout Flow",
      "steps": [
        "User opens Product List Page",
        "User selects product to purchase",
        "User opens Cart Page",
        "User reviews cart contents",
        "User opens Checkout Page",
        "User completes payment"
      ]
    },
    {
      "name": "Admin Dashboard Flow",
      "steps": [
        "Admin opens Admin Dashboard",
        "Admin views analytics",
        "Admin manages settings"
      ]
    }
  ]
}