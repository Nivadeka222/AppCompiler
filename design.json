{
  "entities": [
    {
      "name": "Coffee",
      "description": "Beverage",
      "attributes": [
        "fresh",
        "of the day"
      ]
    },
    {
      "name": "Cart",
      "description": "Shopping cart",
      "attributes": []
    },
    {
      "name": "Offers",
      "description": "Discounts or promotions",
      "attributes": []
    },
    {
      "name": "Menu",
      "description": "List of available items",
      "attributes": []
    },
    {
      "name": "Admin",
      "description": "User with administrative privileges",
      "attributes": [
        "access"
      ]
    }
  ],
  "relationships": [
    {
      "name": "menu_item",
      "description": "A menu item is a coffee",
      "from_entity": "Menu",
      "to_entity": "Coffee",
      "type": "one_to_many"
    },
    {
      "name": "cart_item",
      "description": "A cart item is a coffee",
      "from_entity": "Cart",
      "to_entity": "Coffee",
      "type": "one_to_many"
    },
    {
      "name": "offer_item",
      "description": "An offer item is a coffee",
      "from_entity": "Offers",
      "to_entity": "Coffee",
      "type": "one_to_many"
    },
    {
      "name": "admin_access",
      "description": "An admin has access to the app",
      "from_entity": "Admin",
      "to_entity": "Coffee App",
      "type": "one_to_one"
    }
  ],
  "pages": [
    {
      "name": "LoginPage",
      "path": "/login",
      "description": "Login page for users",
      "access_roles": [
        "user",
        "admin"
      ]
    },
    {
      "name": "MenuPage",
      "path": "/menu",
      "description": "List of available coffee items",
      "access_roles": [
        "user"
      ]
    },
    {
      "name": "CartPage",
      "path": "/cart",
      "description": "Allow users to add and manage items",
      "access_roles": [
        "user"
      ]
    },
    {
      "name": "OffersPage",
      "path": "/offers",
      "description": "Display available discounts and promotions",
      "access_roles": [
        "user"
      ]
    },
    {
      "name": "AdminPage",
      "path": "/admin",
      "description": "Allow admins to manage app settings",
      "access_roles": [
        "admin"
      ]
    }
  ],
  "api_groups": [
    {
      "name": "User API",
      "description": "API for user interactions",
      "endpoints": [
        {
          "method": "GET",
          "path": "/menu",
          "description": "Get list of available coffee items"
        },
        {
          "method": "POST",
          "path": "/cart",
          "description": "Add item to cart"
        },
        {
          "method": "GET",
          "path": "/offers",
          "description": "Get list of available discounts and promotions"
        }
      ]
    },
    {
      "name": "Admin API",
      "description": "API for admin interactions",
      "endpoints": [
        {
          "method": "GET",
          "path": "/admin/settings",
          "description": "Get app settings"
        },
        {
          "method": "POST",
          "path": "/admin/settings",
          "description": "Update app settings"
        }
      ]
    }
  ],
  "flows": [
    {
      "name": "User Login Flow",
      "steps": [
        "User opens LoginPage",
        "User enters username and password",
        "User submits login form",
        "System authenticates user",
        "User is redirected to MenuPage"
      ]
    },
    {
      "name": "User Menu Flow",
      "steps": [
        "User opens MenuPage",
        "User selects coffee item",
        "System adds coffee item to cart",
        "User is redirected to CartPage"
      ]
    },
    {
      "name": "Admin Settings Flow",
      "steps": [
        "Admin opens AdminPage",
        "Admin navigates to settings page",
        "Admin updates app settings",
        "System saves updated settings"
      ]
    }
  ]
}