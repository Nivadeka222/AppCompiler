{
  "base_path": "/api/v1",
  "endpoints": [
    {
      "path": "/fresh-of-the-day",
      "method": "GET",
      "summary": "Get daily coffee selection",
      "roles_allowed": [
        "user"
      ],
      "request_fields": [
        {
          "name": "limit",
          "type": "integer",
          "required": false,
          "source": "query"
        },
        {
          "name": "offset",
          "type": "integer",
          "required": false,
          "source": "query"
        }
      ],
      "response_fields": [
        {
          "name": "id",
          "type": "integer",
          "required": true,
          "source": "table.id"
        },
        {
          "name": "price",
          "type": "float",
          "required": true,
          "source": "table.price"
        },
        {
          "name": "description",
          "type": "text",
          "required": true,
          "source": "table.description"
        }
      ],
      "auth_required": false
    },
    {
      "path": "/cart",
      "method": "GET",
      "summary": "Get user's shopping cart",
      "roles_allowed": [
        "user"
      ],
      "request_fields": [
        {
          "name": "limit",
          "type": "integer",
          "required": false,
          "source": "query"
        },
        {
          "name": "offset",
          "type": "integer",
          "required": false,
          "source": "query"
        }
      ],
      "response_fields": [
        {
          "name": "id",
          "type": "integer",
          "required": true,
          "source": "table.id"
        },
        {
          "name": "items",
          "type": "array",
          "required": true,
          "source": "table.items"
        },
        {
          "name": "total",
          "type": "float",
          "required": true,
          "source": "table.total"
        }
      ],
      "auth_required": false
    },
    {
      "path": "/cart",
      "method": "POST",
      "summary": "Add item to cart",
      "roles_allowed": [
        "user"
      ],
      "request_fields": [
        {
          "name": "item_id",
          "type": "integer",
          "required": true,
          "source": "body"
        }
      ],
      "response_fields": [
        {
          "name": "id",
          "type": "integer",
          "required": true,
          "source": "table.id"
        },
        {
          "name": "items",
          "type": "array",
          "required": true,
          "source": "table.items"
        },
        {
          "name": "total",
          "type": "float",
          "required": true,
          "source": "table.total"
        }
      ],
      "auth_required": false
    },
    {
      "path": "/offers",
      "method": "GET",
      "summary": "Get available discounts",
      "roles_allowed": [
        "user"
      ],
      "request_fields": [
        {
          "name": "limit",
          "type": "integer",
          "required": false,
          "source": "query"
        },
        {
          "name": "offset",
          "type": "integer",
          "required": false,
          "source": "query"
        }
      ],
      "response_fields": [
        {
          "name": "id",
          "type": "integer",
          "required": true,
          "source": "table.id"
        },
        {
          "name": "discount",
          "type": "float",
          "required": true,
          "source": "table.discount"
        },
        {
          "name": "expiration",
          "type": "datetime",
          "required": true,
          "source": "table.expiration"
        }
      ],
      "auth_required": false
    },
    {
      "path": "/menu",
      "method": "GET",
