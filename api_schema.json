          "source": "query"
        }
      ],
      "response_fields": [
        {
          "name": "id",
          "type": "integer",
          "required": true,
          "source": "table.id"
        },
        {
          "name": "discount",
          "type": "float",
          "required": true,
          "source": "table.discount"
        },
        {
          "name": "expiration",
          "type": "datetime",
