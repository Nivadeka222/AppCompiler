          "name": "limit",
          "type": "integer",
          "required": false,
          "source": "query"
        },
        {
          "name": "offset",
          "type": "integer",
          "required": false,
          "source": "query"
        }
      ],
      "response_fields": [
        {
          "name": "id",
          "type": "integer",
          "required": true,
          "source": "table.id"
        },
        {
          "name": "name",
          "type": "text",
          "required": true,
          "source": "table.name"
        },
        {
          "name": "price",
          "type": "float",
          "required": true,
          "source": "table.price"
        }
      ],
      "auth_required": false
    },
    {
      "path": "/admin/login",
      "method": "POST",
