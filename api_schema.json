      "roles_allowed": [
        "admin"
      ],
      "request_fields": [
        {
          "name": "username",
          "type": "string",
          "required": true,
          "source": "body"
        },
        {
          "name": "password",
          "type": "string",
          "required": true,
          "source": "body"
        }
      ],
      "response_fields": [
        {
          "name": "token",
          "type": "string",
          "required": true,
          "source": "table.token"
        }
      ],
      "auth_required": true
    },
